{
  "name": "planbranch",
  "version": "1.0.0",
  "description": "PlanBranch – Express + TypeScript + TypeORM + SQLite",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --ext .ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^6.0.1",
    "typeorm": "^1.0.0",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.1",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "eslint": "^9.23.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0"
